#!/data/data/com.termux/files/usr/bin/bash

# Resolve the script's own directory so we can find sibling files
# (mullvad_dns.py) regardless of cwd.
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

# Define our paths explicitly
TERMUX_HOME="/data/data/com.termux/files/home"
# Tailscale binaries live in ~/bin; runtime logs go to ~/logs; tailscaled's
# persistent session state goes in ~/state.
BIN_DIR="${TERMUX_HOME}/bin"
LOG_DIR="${TERMUX_HOME}/logs"
STATE_DIR="${TERMUX_HOME}/state"
TAILSCALED="${BIN_DIR}/tailscaled"
TAILSCALE="${BIN_DIR}/tailscale"
# tailscaled is launched with --statedir (not just --state). This matters:
# with only --state=<file>, tailscaled persists the *state file* there but
# derives its profile-data directory separately — on Android that lands in a
# non-persistent root path (e.g. /.cache/Tailscale), so the login profile
# (node key) is lost on every restart and you get re-prompted for an auth key
# forever. --statedir keeps the state file AND the profile data together in
# ~/state. The state file itself defaults to <statedir>/tailscaled.state.
STATE_FILE="${STATE_DIR}/tailscaled.state"
LOG_FILE="${LOG_DIR}/tailscaled.log"
PYTHON_BIN="/data/data/com.termux/files/usr/bin/python"

# Persistent config (HEADSCALE_URL etc). Prompted for and saved on
# first run; sourced as shell on subsequent runs.
CONFIG_DIR="${TERMUX_HOME}/.config/termux-vpn-nest"
CONFIG_FILE="${CONFIG_DIR}/config"
[ -f "$CONFIG_FILE" ] && . "$CONFIG_FILE"

# Headscale pre-auth key (generated in the Headscale admin UI).
# Required for first-time registration. Subsequent runs reuse the saved
# session and don't need a key.
# Pass as first argument:  ./start-vpn <key>
# or via env var:          AUTH_KEY=<key> ./start-vpn
# If empty and not yet registered, you'll be prompted.
#
# Special first argument `recover`: skip starting anything and just undo any
# leftover state from a previous run that exited badly (phone killed Termux,
# etc.) — restores Mullvad's DNS from the saved snapshot in /data/local/tmp,
# clears the stale route, resets /etc/resolv.conf and remounts / read-only.
# Use this instead of rebooting when the network is wedged.
#
# `__teardown` is an INTERNAL subcommand the non-root supervisor (see the
# re-exec block below) runs as root after a session ends. It's identical to
# `recover` EXCEPT it never force-resets Mullvad's DNS to default when no
# snapshot is found — a missing snapshot in the teardown path means the run's
# own cleanup already restored it, so there's nothing to do. (`recover`, the
# manual unwedge command, DOES force default in that case.)
MODE="run"
if [ "${1:-}" = "recover" ] || [ "${1:-}" = "--cleanup" ]; then
  MODE="recover"
elif [ "${1:-}" = "__teardown" ]; then
  MODE="teardown"
fi
# Don't treat a subcommand as an auth key. (We leave "$@" intact so a real
# key token survives the su re-exec below and is re-detected as root.)
if [ "$MODE" = "run" ]; then
  AUTH_KEY="${1:-${AUTH_KEY:-}}"
else
  AUTH_KEY=""
fi

# DNS to use for tailscaled's Go resolver during startup (Mullvad will tunnel
# the query). Once tailscaled is up it'll swap /etc/resolv.conf to MagicDNS.
RESOLV_DNS="1.1.1.1"

# Tailscale's MagicDNS server. We tell Mullvad to advertise this as the
# system DNS so split-horizon names resolve everywhere, including
# DoH-defaulting browsers, since Mullvad announces DNS via Android's
# VpnService API.
MAGIC_DNS="100.100.100.100"

# gRPC client + saved DnsOptions location for the Mullvad management API.
MULLVAD_DNS_PY="${SCRIPT_DIR}/mullvad_dns.py"
MULLVAD_DNS_SAVE="/data/local/tmp/start-vpn-mullvad-dns.bin"
# h2 was installed via `pip install --user h2`; expose it to root.
# Auto-detect actual python3.X dir so a Termux Python upgrade won't break it.
MULLVAD_DNS_PYPATH="$(echo "${TERMUX_HOME}/.local/lib/python"*/site-packages 2>/dev/null | awk '{print $1}')"

# Detect the egress interface (Mullvad's tun) by asking the kernel
# which device handles non-Tailscale outbound traffic.
detect_egress_if() {
  ip -4 route get 1.1.1.1 2>/dev/null | awk '/dev/ {for (i=1;i<=NF;i++) if ($i=="dev") {print $(i+1); exit}}'
}

# Install a default route into the 'main' table via Mullvad's tun so
# tailscaled's fwmark-tagged outbound sockets can actually leave the device
# (see the long comment at the call site). Idempotent: it deletes any
# existing default in main first, so it's safe to re-run after a Mullvad
# re-handshake that may have changed the tun.
setup_egress_route() {
  local egress_if
  egress_if=$(detect_egress_if)
  if [ -n "$egress_if" ]; then
    echo "[*] Routing tailscaled's marked traffic via $egress_if (Mullvad)..."
    ip route del default table main >/dev/null 2>&1
    ip route add default dev "$egress_if" table main
  else
    echo "[-] Warning: could not detect egress interface. Is Mullvad connected?"
  fi
}

# Kill any running tailscaled and WAIT for it to actually exit. This matters:
# `pkill` only *sends* a signal — it returns immediately while tailscaled does
# its (multi-second) graceful shutdown, during which it still holds the
# userspace-tun device open. If we launch a fresh tailscaled in that window it
# dies with "TUN device userspace-tun is busy ... device or resource busy" and
# never connects. So poll until the old process is gone, escalating to SIGKILL.
kill_tailscaled() {
  pgrep tailscaled >/dev/null 2>&1 || return 0
  pkill tailscaled >/dev/null 2>&1
  local i
  for i in $(seq 1 10); do
    pgrep tailscaled >/dev/null 2>&1 || return 0
    sleep 1
  done
  # Still alive after ~10s of graceful shutdown — force it and wait again.
  echo "[*] tailscaled didn't exit gracefully; sending SIGKILL..."
  pkill -9 tailscaled >/dev/null 2>&1
  for i in $(seq 1 5); do
    pgrep tailscaled >/dev/null 2>&1 || return 0
    sleep 1
  done
  echo "[-] Warning: tailscaled still present after SIGKILL; the TUN may stay busy."
}

# Snapshot Mullvad's current DnsOptions, then tell its daemon (live, no
# restart) to advertise MagicDNS as the tunnel DNS. Mullvad re-handshakes
# the tunnel as part of applying the change (~3-5s of network blip).
mullvad_dns_set() {
  # Snapshot Mullvad's current DnsOptions so teardown can restore them — but
  # ONLY if we don't already have a snapshot. A leftover snapshot means a
  # previous run set MagicDNS and never tore down, so the *current* DNS is now
  # MagicDNS. Re-saving here would capture that leaked value and "restore" the
  # device into a broken state on exit (DNS pinned to a dead 100.100.100.100).
  # Keep the existing snapshot — it holds the genuine pre-MagicDNS original.
  if [ -f "$MULLVAD_DNS_SAVE" ]; then
    echo "[*] Keeping existing Mullvad DNS snapshot (a previous run left one)."
  else
    echo "[*] Saving Mullvad's current DnsOptions snapshot..."
    PYTHONPATH="$MULLVAD_DNS_PYPATH" "$PYTHON_BIN" "$MULLVAD_DNS_PY" save "$MULLVAD_DNS_SAVE" \
      || { echo "[-] Couldn't reach Mullvad's gRPC socket. Is Mullvad running?"; return 1; }
  fi
  echo "[*] Switching Mullvad's tunnel DNS to $MAGIC_DNS (brief re-handshake)..."
  PYTHONPATH="$MULLVAD_DNS_PYPATH" "$PYTHON_BIN" "$MULLVAD_DNS_PY" custom "$MAGIC_DNS"
  # Wait until Mullvad reports Connected again before moving on, otherwise
  # tailscaled tries to bootstrap through a half-up tunnel.
  for _ in $(seq 1 15); do
    ping -c1 -W2 1.1.1.1 >/dev/null 2>&1 && return 0
    sleep 1
  done
  echo "[-] Mullvad didn't come back within 15s; continuing anyway."
}

# Restore Mullvad's DnsOptions. Mullvad persists this setting across reboots,
# so if we leave it pointing at MagicDNS (100.100.100.100) the device has no
# working DNS the moment Mullvad reconnects — even with tailscaled gone and
# start-vpn never run. That's the "network broken after reboot" failure.
#
# Normal path: restore the exact snapshot we took in mullvad_dns_set.
# If the snapshot is gone (a reboot can wipe /data/local/tmp) we can't know
# the user's original DNS — but we must NOT leave the dead MagicDNS in place,
# so in recover mode we force Mullvad's DNS back to its default as a safe
# baseline. (In the normal run path a missing snapshot means we never changed
# anything, so there's nothing to undo.)
mullvad_dns_restore() {
  if [ -f "$MULLVAD_DNS_SAVE" ]; then
    # Safety net for an already-poisoned snapshot: if the saved blob itself
    # contains MagicDNS, restoring it would just re-apply the dead
    # 100.100.100.100 and wedge DNS. Treat it as poisoned and force Mullvad's
    # DNS back to default instead. This self-heals state left by older buggy
    # runs (and by hard kills mid-session).
    if grep -Fq -- "$MAGIC_DNS" "$MULLVAD_DNS_SAVE" 2>/dev/null; then
      echo "[!] Saved DNS snapshot is poisoned (contains $MAGIC_DNS); forcing Mullvad DNS to default."
      PYTHONPATH="$MULLVAD_DNS_PYPATH" "$PYTHON_BIN" "$MULLVAD_DNS_PY" default \
        && rm -f "$MULLVAD_DNS_SAVE"
      return
    fi
    echo "[*] Restoring Mullvad's original DnsOptions (brief re-handshake)..."
    PYTHONPATH="$MULLVAD_DNS_PYPATH" "$PYTHON_BIN" "$MULLVAD_DNS_PY" restore "$MULLVAD_DNS_SAVE" \
      && rm -f "$MULLVAD_DNS_SAVE"
    return
  fi
  if [ "$MODE" = "recover" ]; then
    echo "[*] No DNS snapshot found; forcing Mullvad DNS back to default..."
    PYTHONPATH="$MULLVAD_DNS_PYPATH" "$PYTHON_BIN" "$MULLVAD_DNS_PY" default
  fi
}

# Termux's session drawer (and the notification) shows whatever title a session
# sets via the OSC terminal escape, so we set one while the VPN is up to make
# the VPN session easy to pick out among many, and clear it on teardown so a
# freed session stops claiming it's running the VPN. Write to the controlling
# terminal directly (not stdout, which a redirect could swallow); harmless if
# there's no tty. Override the text with VPN_SESSION_TITLE=... start-vpn.
SESSION_TITLE="${VPN_SESSION_TITLE:-🔒 vpn-nest}"
set_term_title() { printf '\033]0;%s\007' "$1" >/dev/tty 2>/dev/null; }

# Run the privileged work under su — but DON'T `exec` into it. We deliberately
# keep THIS non-root shell alive as a supervisor.
#
# Why: under MagiskSU the command given to `su -c` runs in its own session,
# reparented to the magisk daemon — it is NOT in the terminal's foreground
# process group. So Ctrl+C's SIGINT never reaches it, and when the su client
# dies magiskd SIGKILLs the root child. A cleanup trap *inside* the su'd
# process therefore can never run on Ctrl+C, which is exactly why Mullvad's
# DNS was left toggled on after exit.
#
# This outer shell, by contrast, is a normal Termux process in the terminal's
# foreground group, so it reliably catches Ctrl+C (and TERM/HUP). On any of
# those — or when the root process returns on its own — we run teardown as
# root via a fresh `su -c ... __teardown`, which restores Mullvad's DNS,
# kills tailscaled, clears the route, and remounts ro. Teardown is idempotent
# and snapshot-based, so running it even after a clean inner exit is safe.
if [ "$EUID" -ne 0 ]; then
  SELF="$(readlink -f "$0")"
  SELF_Q="$(printf '%q ' "$SELF")"

  # Only a real session ("run") gets the badge; recover/teardown are transient.
  [ "$MODE" = "run" ] && set_term_title "$SESSION_TITLE"

  run_root_teardown() {
    su -c "${SELF_Q}__teardown"
  }
  on_supervisor_signal() {
    trap - INT TERM HUP
    printf '\n[*] Interrupt received — tearing down the VPN as root...\n'
    run_root_teardown
    [ "$MODE" = "run" ] && set_term_title ""
    exit 0
  }
  trap on_supervisor_signal INT TERM HUP

  # Hand control to the privileged run. Blocks until the root process exits
  # (or Ctrl+C trips the trap above, which tears down and exits).
  su -c "$(printf '%q ' "$SELF" "$@")"
  rc=$?

  # Root process ended without us catching a signal (normal/error exit, or it
  # was killed). Run teardown to guarantee the network is restored regardless
  # of whether the inner cleanup got to run.
  run_root_teardown
  [ "$MODE" = "run" ] && set_term_title ""
  exit "$rc"
fi

# First-run setup: prompt for the Headscale URL and persist it. Skipped in
# recover mode, which only tears down leftover state and needs no config.
if [ "$MODE" = "run" ] && [ -z "${HEADSCALE_URL:-}" ]; then
  echo "[*] First-time setup: need your Headscale server URL."
  read -r -p "    Headscale URL (e.g. https://vpn.example.com): " HEADSCALE_URL
  if [ -z "$HEADSCALE_URL" ]; then
    echo "[-] No URL provided. Aborting."
    exit 1
  fi
  mkdir -p "$CONFIG_DIR"
  printf 'HEADSCALE_URL=%q\n' "$HEADSCALE_URL" > "$CONFIG_FILE"
  echo "[*] Saved to $CONFIG_FILE"
fi

# Make sure the tailscale binaries are where we expect them. They aren't
# shipped with this repo — download the static builds from
# https://pkgs.tailscale.com/stable/#static and drop them in ~/bin.
# (Recover mode doesn't need them — it only undoes leftover state.)
if [ "$MODE" = "run" ] && { [ ! -x "$TAILSCALED" ] || [ ! -x "$TAILSCALE" ]; }; then
  echo "[-] Missing tailscale binaries in $BIN_DIR." >&2
  echo "    Expected: $TAILSCALE and $TAILSCALED" >&2
  echo "    Download the static builds from https://pkgs.tailscale.com/stable/#static" >&2
  echo "    and place them in $BIN_DIR (chmod +x)." >&2
  exit 1
fi

# Ensure the log and state directories exist before tailscaled writes to them.
mkdir -p "$LOG_DIR" "$STATE_DIR"

# Undo every system-wide change we made, in reverse order. This is the
# function that keeps the phone usable after we exit: if it doesn't run,
# the device is left with Mullvad's DNS pinned to a now-dead MagicDNS
# address, /etc/resolv.conf pointing at the same dead server, and a stale
# default route in the main table — which is exactly the "no internet until
# I reboot" symptom.
#
# It's guarded so it runs exactly once, and idempotent so partial startups
# (tailscaled never came up, route never added, etc.) clean up fine — every
# step tolerates "nothing to undo".
CLEANED_UP=0
cleanup() {
  [ "$CLEANED_UP" -eq 1 ] && return
  CLEANED_UP=1
  # Stop re-entry: we don't want a second signal (or the EXIT trap firing
  # after our own `exit`) to run this again mid-flight.
  trap - EXIT SIGINT SIGTERM SIGHUP

  echo -e "\n[!] Shutting down and restoring the network..."

  echo "[*] Disconnecting from Headscale..."
  $TAILSCALE down >/dev/null 2>&1

  echo "[*] Killing tailscaled background engine..."
  # Wait for it to fully exit so a subsequent run can reopen the TUN cleanly.
  kill_tailscaled

  # Remove the main-table default route we added so Mullvad's tun isn't
  # left with a dangling route if it disconnects.
  ip route del default table main >/dev/null 2>&1

  # Hand Mullvad's DNS back to whatever it was before we started. This is
  # the device-wide DNS, so skipping it breaks name resolution for every app.
  mullvad_dns_restore

  # tailscaled rewrites /etc/resolv.conf to MagicDNS (100.100.100.100) once
  # connected. With tailscaled gone that server is dead, so put a working
  # resolver back before we remount read-only (we need rw to write it).
  if [ -w /etc/resolv.conf ] || [ -d /etc ]; then
    echo "nameserver $RESOLV_DNS" > /etc/resolv.conf 2>/dev/null
  fi

  # Restore the read-only mount we flipped on startup.
  mount -o remount,ro / >/dev/null 2>&1

  echo "[+] All cleaned up. Network restored."
  exit 0
}

# Run cleanup on Ctrl+C (INT), termination (TERM), the controlling terminal
# going away (HUP — e.g. Termux swiped from recents or the su session dying),
# and on ANY other exit (EXIT) so a failure *after* we've started changing
# system state still tears everything back down instead of leaving the phone
# wedged. The trap is registered here, before the first state-mutating step.
trap cleanup EXIT SIGINT SIGTERM SIGHUP

# Recover/teardown modes: don't start anything — just run cleanup to undo
# leftover state, then exit. `recover` is the manual unwedge command;
# `__teardown` is what the non-root supervisor runs after every session.
# Remount rw first so cleanup can rewrite /etc/resolv.conf.
if [ "$MODE" = "recover" ] || [ "$MODE" = "teardown" ]; then
  [ "$MODE" = "recover" ] && echo "[*] Recover mode: undoing leftover state from a previous run..."
  mount -o remount,rw / 2>/dev/null
  cleanup
fi

# Kill any stray tailscaled processes before starting — and WAIT for them to
# release the userspace-tun device, or our new daemon fails to start.
kill_tailscaled

# tailscaled needs to read AND rewrite /etc/resolv.conf at runtime:
#   - on startup, to resolve $HEADSCALE_URL (needs `nameserver` line)
#   - once connected, to swap to MagicDNS (100.100.100.100) so peer
#     names like 10.0.0.1 / *.homefree.vpn resolve
# Android mounts / read-only by default, so MagicDNS swap fails silently.
# Remount rw for the whole session; cleanup() puts it back to ro.
echo "[*] Remounting / rw so tailscaled can manage /etc/resolv.conf..."
mount -o remount,rw / 2>/dev/null
if [ ! -f /etc/resolv.conf ]; then
  echo "[*] Seeding /etc/resolv.conf (nameserver $RESOLV_DNS)..."
  echo "nameserver $RESOLV_DNS" > /etc/resolv.conf
fi

# NOTE: We deliberately do NOT touch Mullvad's DNS yet. Swapping it to
# MagicDNS (100.100.100.100) only makes sense once tailscaled is connected
# and that address actually answers; doing it now would black-hole DNS for
# the whole device — including the browser you need to open the Headscale
# admin UI to generate a pre-auth key. The swap happens after `tailscale up`.

# tailscaled sets fwmark 0x80000 on its own outbound sockets so they don't
# loop back through its TUN. Routing rule 5210 sends those marked packets
# to the 'main' table, which on Android has no default route. Result:
# every dial returns "network is unreachable" before any login URL is
# generated. Fix: copy the egress interface (Mullvad's tun) into main.
setup_egress_route

echo "[*] Starting tailscaled engine in background..."
echo "[*] tailscaled log: $LOG_FILE"
# Log tailscaled stdout/stderr so we can debug hangs
: > "$LOG_FILE"
# Nested-tunnel MTU clamp. tailscaled sizes its tun assuming a ~1500B physical
# underlay (→ default 1280), but here the underlay IS Mullvad's tun (also 1280).
# A full-size 1280 inner packet + WireGuard's ~60-80B overhead exceeds Mullvad's
# 1280 MTU and gets silently dropped — small packets (DNS, MagicDNS, metadata
# sync, pings) pass, but bulk transfers (photo/video uploads) stall mid-stream.
# Clamp the inner MTU so inner+overhead fits inside Mullvad. 1200 measured working
# (upload 16KB/s stalled → 422KB/s); drop to ~1160 if large transfers still hang.
export TS_DEBUG_MTU="${TS_DEBUG_MTU:-1200}"
# Disable peer Path-MTU Discovery. TS_DEBUG_MTU only sizes the inner tun; magicsock
# separately probes the OUTER WireGuard/UDP path and, over a normal underlay, settles
# on ~1360. But that outer traffic is routed through Mullvad's 1280-MTU tun, so 1360B
# datagrams exceed 1280 and are silently dropped (ICMP-too-big can't get back through
# Mullvad, so the probes falsely "succeed") — bulk transfers stall even with the inner
# clamp in place. Disabling PMTUD forces conservative sizing based on TS_DEBUG_MTU.
export TS_DEBUG_ENABLE_PMTUD="${TS_DEBUG_ENABLE_PMTUD:-false}"
$TAILSCALED --tun=userspace-tun --statedir="$STATE_DIR" >>"$LOG_FILE" 2>&1 &

# Wait for tailscaled's local API socket to be responsive (up to ~15s).
# `tailscale status` returns 0 when logged in, non-zero with "Logged out"
# in the output when not — either is a signal the daemon is ready.
for _ in $(seq 1 15); do
  $TAILSCALE status >/dev/null 2>&1 && break
  $TAILSCALE status 2>&1 | grep -qi "logged out" && break
  sleep 1
done

echo "[*] Initiating connection to Headscale..."
echo "[*] KEEP THIS TERMINAL OPEN. Press Ctrl+C to disconnect."
echo "--------------------------------------------------------"

# Ask tailscaled whether we already have a valid session. If not (and no
# key was supplied), prompt for a pre-auth key before calling `up`.
if [ -z "$AUTH_KEY" ] && $TAILSCALE status 2>&1 | grep -qi "logged out"; then
  echo "[*] Client is not yet registered."
  echo "    Generate a pre-auth key in the Headscale admin UI and paste it here."
  read -r -p "Pre-auth key: " AUTH_KEY
  if [ -z "$AUTH_KEY" ]; then
    echo "[-] No key provided. Aborting."
    cleanup
  fi
fi

# Call the connection tool. --accept-routes is required so subnet routes
# advertised by tailnet peers (e.g. 10.0.0.0/24 via your home router)
# actually get installed in the routing table.
TS_UP_ARGS=(--login-server "$HEADSCALE_URL" --accept-routes)
if [ -n "$AUTH_KEY" ]; then
  echo "[*] Registering with pre-auth key..."
  $TAILSCALE up "${TS_UP_ARGS[@]}" --auth-key "$AUTH_KEY"
else
  echo "[*] Reconnecting with saved session..."
  $TAILSCALE up "${TS_UP_ARGS[@]}"
fi

# Now that tailscaled is connected and MagicDNS (100.100.100.100) actually
# answers, push it to Mullvad so every app on the device — including
# DoH-defaulting browsers — resolves split-horizon names. Doing this here,
# after `up`, is what keeps normal DNS working during the auth-key step above.
mullvad_dns_set

# mullvad_dns_set re-handshakes Mullvad's tunnel, which can swap the egress
# tun out from under the route we installed earlier. Re-assert it so
# tailscaled's marked traffic keeps a valid exit.
setup_egress_route

# Keep the script alive so the trap can listen for Ctrl+C
while true; do
  sleep 1
done
